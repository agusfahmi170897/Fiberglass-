<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Galeri Aset — Cahaya Putra Fiberglass</title>
<link rel="icon" type="image/png" href="images/favicon.png">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700;800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@500;600&display=swap" rel="stylesheet">
<link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">

<script src="https://cdn.tailwindcss.com"></script>
<script>
  if (window.tailwind) {
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            forest: { 50:'#eefaf1',100:'#d5f2dc',600:'#2E7D32',700:'#256b2a',900:'#1a481f' },
            stone: { 25:'#fbfaf7',50:'#f7f6f2',100:'#f0eee7',200:'#e4e1d6',400:'#a6a08a',500:'#7d7666',700:'#433e36',900:'#1b1916' },
            amber: { 500:'#f5b301' }
          },
          fontFamily: {
            display: ['"Plus Jakarta Sans"','sans-serif'],
            body: ['Inter','sans-serif'],
            mono: ['"JetBrains Mono"','monospace']
          }
        }
      }
    };
  }
</script>
<style>
  body { font-family: 'Inter', sans-serif; }
  .font-display { font-family: 'Plus Jakarta Sans', sans-serif; }
  .font-mono { font-family: 'JetBrains Mono', monospace; }
</style>
</head>
<body class="bg-stone-25 text-stone-800">

<header class="border-b border-stone-200 bg-white">
  <div class="max-w-6xl mx-auto px-5 sm:px-8 py-6 flex items-center gap-3">
    <img src="images/logo.png" alt="Logo Cahaya Putra Fiberglass" class="h-11 w-auto object-contain" />
    <div>
      <h1 class="font-display font-extrabold text-lg text-stone-900">Galeri Aset Visual</h1>
      <p class="text-xs font-mono text-stone-400">Cahaya Putra Fiberglass — referensi logo &amp; foto produk</p>
    </div>
  </div>
</header>

<main class="max-w-6xl mx-auto px-5 sm:px-8 py-12 space-y-16">

  <!-- ===== LOGO ===== -->
  <section id="logo">
    <div class="flex items-center gap-2 mb-6">
      <span class="font-mono text-xs font-semibold tracking-wider text-forest-600 uppercase">01 — Logo</span>
      <span class="h-px flex-1 bg-stone-200"></span>
    </div>
    <div class="grid sm:grid-cols-2 gap-5">
      <div class="rounded-2xl border border-stone-200 bg-white p-10 flex flex-col items-center justify-center gap-3">
        <img src="images/logo.png" alt="Logo di atas latar terang" class="h-32 w-auto object-contain" />
        <p class="text-xs font-mono text-stone-400">Latar terang</p>
      </div>
      <div class="rounded-2xl border border-stone-800 bg-stone-900 p-10 flex flex-col items-center justify-center gap-3">
        <img src="images/logo.png" alt="Logo di atas latar gelap" class="h-32 w-auto object-contain rounded-lg bg-white p-2" />
        <p class="text-xs font-mono text-stone-400">Latar gelap (dengan bantalan putih)</p>
      </div>
    </div>
  </section>

  <!-- ===== FOTO PRODUK ===== -->
  <section id="produk">
    <div class="flex items-center gap-2 mb-6">
      <span class="font-mono text-xs font-semibold tracking-wider text-forest-600 uppercase">02 — Foto Produk</span>
      <span class="h-px flex-1 bg-stone-200"></span>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">

      <figure class="rounded-2xl border border-stone-200 bg-white overflow-hidden">
        <div class="bg-forest-50 p-4"><img src="images/produk-1-pilah.jpg" alt="Bak Sampah 1 Pilah" class="w-full h-auto object-contain rounded-xl" /></div>
        <figcaption class="px-4 py-3 text-sm font-semibold text-stone-700">Bak Sampah 1 Pilah</figcaption>
      </figure>

      <figure class="rounded-2xl border border-stone-200 bg-white overflow-hidden">
        <div class="bg-forest-50 p-4"><img src="images/produk-2-pilah.jpg" alt="Bak Sampah 2 Pilah" class="w-full h-auto object-contain rounded-xl" /></div>
        <figcaption class="px-4 py-3 text-sm font-semibold text-stone-700">Bak Sampah 2 Pilah</figcaption>
      </figure>

      <figure class="rounded-2xl border border-stone-200 bg-white overflow-hidden">
        <div class="bg-forest-50 p-4"><img src="images/produk-3-pilah.jpg" alt="Bak Sampah 3 Pilah" class="w-full h-auto object-contain rounded-xl" /></div>
        <figcaption class="px-4 py-3 text-sm font-semibold text-stone-700">Bak Sampah 3 Pilah</figcaption>
      </figure>

      <figure class="rounded-2xl border border-stone-200 bg-white overflow-hidden">
        <div class="bg-forest-50 p-4"><img src="images/produk-4-pilah.jpg" alt="Bak Sampah 4 Pilah" class="w-full h-auto object-contain rounded-xl" /></div>
        <figcaption class="px-4 py-3 text-sm font-semibold text-stone-700">Bak Sampah 4 Pilah</figcaption>
      </figure>

      <figure class="rounded-2xl border border-stone-200 bg-white overflow-hidden">
        <div class="bg-forest-50 p-4"><img src="images/produk-5-pilah.jpg" alt="Bak Sampah 5 Pilah" class="w-full h-auto object-contain rounded-xl" /></div>
        <figcaption class="px-4 py-3 text-sm font-semibold text-stone-700">Bak Sampah 5 Pilah</figcaption>
      </figure>

      <figure class="rounded-2xl border border-dashed border-stone-300 bg-stone-50 overflow-hidden flex flex-col items-center justify-center text-center p-6 min-h-[180px]">
        <i class='bx bx-image-add text-3xl text-stone-300'></i>
        <figcaption class="mt-2 text-sm font-semibold text-stone-400">Tempat Sampah Outdoor<br><span class="text-xs font-normal">(foto menyusul)</span></figcaption>
      </figure>

    </div>
  </section>

  <!-- ===== GALERI ===== -->
  <section id="galeri">
    <div class="flex items-center gap-2 mb-6">
      <span class="font-mono text-xs font-semibold tracking-wider text-forest-600 uppercase">03 — Galeri (dipakai di landing page)</span>
      <span class="h-px flex-1 bg-stone-200"></span>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
      <img src="images/produk-1-pilah.jpg" alt="Galeri 1 Pilah" class="w-full h-auto object-contain rounded-2xl border border-stone-200 bg-forest-50 p-3" />
      <img src="images/produk-2-pilah.jpg" alt="Galeri 2 Pilah" class="w-full h-auto object-contain rounded-2xl border border-stone-200 bg-forest-50 p-3" />
      <img src="images/produk-3-pilah.jpg" alt="Galeri 3 Pilah" class="w-full h-auto object-contain rounded-2xl border border-stone-200 bg-forest-50 p-3" />
      <img src="images/produk-4-pilah.jpg" alt="Galeri 4 Pilah" class="w-full h-auto object-contain rounded-2xl border border-stone-200 bg-forest-50 p-3" />
      <img src="images/produk-5-pilah.jpg" alt="Galeri 5 Pilah" class="w-full h-auto object-contain rounded-2xl border border-stone-200 bg-forest-50 p-3" />
    </div>
    <p class="text-xs text-stone-400 mt-4">Catatan: galeri di landing page saat ini memakai ulang 5 foto produk yang sama di atas.</p>
  </section>

</main>

<footer class="border-t border-stone-200 py-8 text-center text-xs text-stone-400">
  Galeri aset internal — bukan bagian dari landing page utama.
</footer>

</body>
</html>
